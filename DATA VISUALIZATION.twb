      <aliases enabled='yes' />
      <column caption='PROFIT RANK(DESC)' datatype='integer' name='[Calculation_2136938677346304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Profit]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='PROFIT RANK(ASC)' datatype='integer' name='[Calculation_2136938677649409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(-SUM([Profit]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='TOP BOTTOM 10' datatype='string' name='[Calculation_2136938677936130]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2136938677346304] &lt;= 10 THEN &quot;Top 10&quot;&#13;&#10;ELSEIF [Calculation_2136938677649409] &lt;= 10 THEN &quot;Bottom 10&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Selected State' datatype='string' name='[Calculation_2136938706780164]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL(MIN([State])) THEN &quot;All States&quot;&#13;&#10;ELSE MIN([State])&#13;&#10;END' />
      </column>
      <column caption='SELECTED STATE' datatype='string' name='[Calculation_2136938709225478]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNTD([State]) = 1 THEN ATTR([State])&#13;&#10;ELSE &quot;All States&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit % of Total' datatype='real' name='[Calculation_2136938730905608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / TOTAL(SUM([Profit]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='profit ratio r' datatype='real' name='[Calculation_2136941855203338]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Profit Ratio Correct' datatype='real' name='[Calculation_2136941856256011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='profit ratio' datatype='real' name='[Calculation_3365363446591488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[Name]' type='nominal' />
